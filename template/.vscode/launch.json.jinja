{
    "version": "0.2.0",
    "configurations": [
{%- if project_type == 'reflex' %}
        {
            "name": "Reflex Debug",
            "type": "debugpy",
            "request": "launch",
            "module": "reflex",
            "args": [
                "run"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "VITE_EXPERIMENTAL_HMR": "1"
            },
            "autoReload": {
                "enable": true,
                "pattern": [
                    "**/*.py"
                ]
            },
            "justMyCode": false
        },
        {
            "name": "Attach to Reflex",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            }
        }
{%- else %}
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Python: Module ({{ package_name }})",
            "type": "debugpy",
            "request": "launch",
            "module": "{{ package_name }}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        }
{%- endif %}
    ]
}
