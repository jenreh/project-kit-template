// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
	"name": "{{ project_name }}-dev",
	"dockerComposeFile": "docker-compose.yml",
	"service": "app",
	"remoteUser": "vscode",
	"workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
	"containerEnv": {
		"WORKSPACE": "/workspaces/${localWorkspaceFolderBasename}",
		"UV_PROJECT_ENVIRONMENT": ".venv",
		"VIRTUAL_ENV": "/workspaces/${localWorkspaceFolderBasename}/.venv"
	},
	"mounts": [
		"source=${localEnv:HOME}${env:USERPROFILE}/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached"
	],
	"customizations": {
		"vscode": {
			"settings": {
				"python.defaultInterpreterPath": "/usr/local/bin/python",
				"python.envFile": "${workspaceFolder}/.env"
			},
			"extensions": [
				"-dbaeumer.vscode-eslint",
				"-ms-python.autopep8", // disabled because we are using ruff
				"charliermarsh.ruff",
				"esbenp.prettier-vscode",
				"fill-labs.dependi",
				"GitHub.copilot-chat",
				"GitHub.copilot",
				"GitHub.remotehub",
				"github.vscode-github-actions",
				"GitHub.vscode-pull-request-github",
				"humao.rest-client",
{%- if include_terraform %}
				"hashicorp.terraform",
{%- if cloud_provider == 'azure' %}
				"ms-azuretools.vscode-azureterraform",
{%- elif cloud_provider == 'aws' %}
				"amazonwebservices.aws-toolkit-vscode",
{%- endif %}
{%- endif %}
{%- if include_docker %}
				"ms-azuretools.vscode-docker",
{%- endif %}
{%- if project_type == 'reflex' or include_db %}
				"ms-ossdata.vscode-pgsql",
{%- endif %}
				"astral-sh.ty",
				"ms-python.python",
				"mutantdino.resourcemonitor",
				"naumovs.color-highlight",
				"redhat.vscode-yaml",
				"sndst00m.vscode-native-svg-preview",
				"tamasfe.even-better-toml",
				"teticio.python-envy",
				"Upstash.context7-mcp",
				"vscode-icons-team.vscode-icons",
				"yzhang.markdown-all-in-one"
				//				"ms-azuretools.vscode-containers",
			]
		}
	},
	"features": {
		"ghcr.io/devcontainers/features/common-utils:2.5.9": {
			"configureZshAsDefaultShell": true,
			"username": "vscode"
		},
		"ghcr.io/devcontainers/features/git:1.3.5": {},
		"ghcr.io/devcontainers/features/github-cli:1.1.0": {}{% if include_docker or include_terraform or project_type == "reflex" %},{% endif %}
{%- if include_docker %}
		"ghcr.io/devcontainers/features/docker-outside-of-docker:1.10.0": {}{% if include_terraform or project_type == "reflex" %},{% endif %}
{%- endif %}
{%- if include_terraform %}
{%- if cloud_provider == 'azure' %}
		"ghcr.io/devcontainers/features/azure-cli:1.2.8": {},
{%- elif cloud_provider == 'aws' %}
		"ghcr.io/devcontainers/features/aws-cli:1.1.0": {},
{%- endif %}
		"ghcr.io/devcontainers/features/terraform:1.4.2": {
			"installTerraformDocs": "true",
			"installTFsec": "true"
		}{% if project_type == "reflex" %},{% endif %}
{%- endif %}
{%- if project_type == "reflex" %}
		"ghcr.io/devcontainers/features/node:2.0.0": {
			"version": "24"
		}
{%- endif %}
	},
	"postCreateCommand": {
		"initialize environment": "bash ./.devcontainer/post-create.sh"
	},
	"postAttachCommand": {
		"install dependencies": "uv sync"
	}
}
